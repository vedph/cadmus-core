		<IsTestProject>true</IsTestProject>
	</PropertyGroup>

	<ItemGroup>
		<None Remove="Assets\Config.json" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="Assets\Config.json" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.NET.Test.Sdk" />
